# Local PostgreSQL example. For Supabase/Neon, replace this with the cloud JDBC URL.
DATABASE_URL=jdbc:postgresql://localhost:5432/jobswipe
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
JWT_SECRET=replace_with_a_very_long_random_secret_for_hmac_signing_at_least_32_chars
UPLOAD_DIR=uploads
FRONTEND_URL=http://localhost:3000
APP_DEV_MODE=true

# Optional: use this only when PostgreSQL is not available for UI-only local demos.
# SPRING_PROFILES_ACTIVE=dev-fallback
